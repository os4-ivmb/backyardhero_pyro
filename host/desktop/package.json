{
  "name": "backyardhero-desktop",
  "productName": "Backyard Hero",
  "version": "0.30.14",
  "description": "Backyard Hero host - desktop bundle (Next.js UI + Python services + serial bridge) for macOS and Windows.",
  "private": true,
  "main": "src/main.js",
  "author": "Backyard Hero",
  "scripts": {
    "start": "electron .",
    "build:resources": "node scripts/build-resources.mjs",
    "dist": "node scripts/build-resources.mjs && electron-builder",
    "dist:mac": "node scripts/build-resources.mjs && electron-builder --mac",
    "dist:win": "node scripts/build-resources.mjs && electron-builder --win",
    "postinstall": "echo 'Run npm run dist to build an installer. See README.md.'"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
