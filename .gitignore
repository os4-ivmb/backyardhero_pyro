# Python
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Operator config overrides (dongle port/baud, protocol knobs,
# default_location). Written by the UI / install script, layered on top of
# the git-tracked host/config/systemcfg.json at read time. Never committed.
host/config/systemcfg.user.json

host/data/log/*
host/data/backyardhero.db
host/data/ledstate
host/data/state
host/data/leddata
host/data/webactstate
host/data/byh_show_state
host/data/update-backups/
*.state.*

**/.DS_Store
host/byh_app/backyardhero/public/uploads/
devices/os4_receiver/.build/
devices/os4_dongle/.build/
host/data/backyardhero.db.backup*
host/data/last_scan.json


# Next.js
.next/
node_modules/
.env.local
.env.development.local
.env.production.local
.env.test.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
out/
*/.DS_Store
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Thumbs.db (Windows)
Thumbs.db
ehthumbs.db

# Firmware build artifacts (produced by devices/utils/build_{receiver,dongle}.sh).
# We deliberately keep the bin/ directories themselves (they hold a
# README.md / .gitkeep so the layout is documented in-tree), but the
# generated .bin files are large, churn every build, and any operator
# who needs a binary builds it locally. The dongle UI flasher and
# update_dongle.sh both compile-on-demand from devices/os4_dongle/.
devices/os4_receiver/bin/*.bin
devices/os4_dongle/bin/*.bin
